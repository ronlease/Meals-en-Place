@startuml context
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

LAYOUT_WITH_LEGEND()

title System Context Diagram for Meals en Place

Person(user, "User", "Single local user who manages pantry inventory, browses recipes, builds meal plans, and tracks produce seasonality.")

System(mep, "Meals en Place", "Personal recipe and meal planning tool. Tracks pantry, fridge, and freezer inventory; matches ingredients against recipes; generates waste-minimizing meal plans; identifies seasonal produce.")

System_Ext(claude, "Claude API", "AI service providing unit of measure normalization, container reference flagging, dietary classification, recipe match feasibility and substitution suggestions, and meal plan optimization.")
System_Ext(themealdb, "TheMealDB API", "Free, open recipe data source. No auth required. Used to import recipes by search term or category.")
Rel(user, mep, "Manages inventory, browses recipes, builds meal plans", "HTTP localhost")
Rel(mep, claude, "Normalizes units of measure, flags container references, classifies diets, evaluates substitutions, optimizes meal plans", "HTTPS/JSON")
Rel(mep, themealdb, "Imports recipes", "HTTPS/JSON")

@enduml
