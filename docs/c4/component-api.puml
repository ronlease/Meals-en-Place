@startuml component-api
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

LAYOUT_WITH_LEGEND()

title Component Diagram for API Container — Meals en Place

Container_Ext(web, "Angular Web App", "Angular 21, Angular Material", "Frontend SPA")
ContainerDb(db, "Database", "PostgreSQL", "Inventory, recipes, meal plans, shopping lists, seasonality, preferences")
System_Ext(claude, "Claude API", "Unit of measure normalization, dietary classification, meal plan optimization, substitution suggestions")

Container_Boundary(api, "API (ASP.NET Core 10, EF Core 10)") {

    ' === Feature Components ===

    Component(inventory, "Inventory Component", "InventoryController, ReferenceDataController, InventoryService, InventoryRepository", "CRUD for pantry, fridge, and freezer items with container reference detection")
    Component(recipeImport, "Recipe Component", "RecipeImportController, RecipeImportService", "Manual recipe creation, library listing, and detail retrieval. Bulk catalog ingested offline via Tools.Ingest rather than through this component.")
    Component(recipeMatching, "Recipe Matching Component", "RecipeMatchingController, RecipeMatchingService", "Scores recipes against inventory. Classifies Full, Near, and Partial matches")
    Component(containerResolution, "Container Resolution Component", "ContainerResolutionController, ContainerResolutionService", "Resolve container references (can, jar, box) to declared weights and volumes")
    Component(mealPlan, "Meal Plan Component", "MealPlanController, MealPlanSlotsController, MealPlanService, MealConsumptionService", "Generate weekly meal plans, swap slots, score by waste reduction and seasonality, mark slots as eaten with optional inventory auto-deplete and audit-based restore")
    Component(shoppingList, "Shopping List Component", "ShoppingListController, StandaloneShoppingListController, ShoppingListService", "Derive shopping lists from meal plan gaps or standalone recipe additions")
    Component(wasteReduction, "Waste Reduction Component", "WasteAlertController, WasteAlertService", "Scan for expiring items, match against recipes, create alerts")
    Component(seasonalProduce, "Seasonal Produce Component", "SeasonalProduceController, SeasonalProduceService", "Query seasonality windows for current month (USDA Zone 7a)")
    Component(userPreferences, "User Preferences Component", "UserPreferencesController", "Get and update display system preference (Imperial or Metric)")
    Component(settings, "Settings Component", "SettingsController, ClaudeTokenStore, ClaudeAvailability", "BYO Anthropic API key save/test/clear, encrypted at rest. Exposes IClaudeAvailability so Claude-backed services gate on a configured key")

    ' === Infrastructure Components ===

    Component(claudeClient, "Claude AI Client", "ClaudeService", "Dietary classification, unit of measure resolution, meal plan optimization, substitution suggestions (currently stub)")
    Component(anthropicTestClient, "Anthropic Test Client", "AnthropicTestClient", "Minimal HTTP client that issues a one-token Messages API call to verify user-supplied keys from the Settings page")
    Component(dataAccess, "Data Access", "MealsEnPlaceDbContext", "EF Core DbContext with 13 entity configurations")

    ' === Common / Shared Components ===

    Component(unitOfMeasureServices, "Unit of Measure Services", "UnitOfMeasureConversionService, UnitOfMeasureNormalizationService, UnitOfMeasureDisplayConverter", "Convert to base units, parse measure strings, convert base units to display units per user preference")
    Component(containerDetector, "Container Reference Detector", "ContainerReferenceDetector", "Detects container keywords (can, jar, box, packet) in ingredient strings")
    Component(inputSanitizer, "Input Sanitizer", "InputSanitizer", "Strips HTML, control characters, enforces length limits")
}

' === External → Feature Component relationships ===

Rel(web, inventory, "Manages inventory items", "HTTP/JSON")
Rel(web, recipeImport, "Creates manual recipes, reads library", "HTTP/JSON")
Rel(web, recipeMatching, "Requests recipe matches", "HTTP/JSON")
Rel(web, containerResolution, "Resolves container references", "HTTP/JSON")
Rel(web, mealPlan, "Generates and edits meal plans", "HTTP/JSON")
Rel(web, shoppingList, "Derives shopping lists", "HTTP/JSON")
Rel(web, wasteReduction, "Views waste alerts", "HTTP/JSON")
Rel(web, seasonalProduce, "Queries seasonal produce", "HTTP/JSON")
Rel(web, userPreferences, "Gets and updates preferences", "HTTP/JSON")
Rel(web, settings, "Saves / tests / removes the Claude API key", "HTTP/JSON")

' === Feature → Infrastructure relationships ===

Rel(inventory, dataAccess, "Reads/Writes inventory", "EF Core")
Rel(inventory, containerDetector, "Detects container references in entries")
Rel(recipeImport, dataAccess, "Reads/Writes recipes and ingredients", "EF Core")
Rel(recipeImport, containerDetector, "Detects container references on manual entry")
Rel(recipeImport, claudeClient, "Requests dietary classification (when key configured)")
Rel(recipeImport, settings, "Gates Claude calls on IClaudeAvailability")
Rel(recipeMatching, unitOfMeasureServices, "Converts quantities for comparison")
Rel(recipeMatching, claudeClient, "Evaluates substitutions for NearMatch candidates (when key configured)")
Rel(recipeMatching, settings, "Gates Claude calls on IClaudeAvailability")
Rel(containerResolution, dataAccess, "Reads/Writes resolved references", "EF Core")
Rel(mealPlan, unitOfMeasureServices, "Converts quantities for scoring")
Rel(mealPlan, claudeClient, "Optimizes meal plan for variety and waste reduction (when key configured)")
Rel(mealPlan, settings, "Gates Claude calls on IClaudeAvailability")
Rel(mealPlan, dataAccess, "Deducts inventory + writes audit rows on consume; restores on unconsume", "EF Core")
Rel(unitOfMeasureServices, settings, "Gates Claude fallback on IClaudeAvailability")
Rel(settings, anthropicTestClient, "Tests user-supplied key")
Rel(shoppingList, unitOfMeasureServices, "Converts and formats display quantities")
Rel(wasteReduction, dataAccess, "Reads expiry data and recipes", "EF Core")
Rel(seasonalProduce, dataAccess, "Reads seasonality windows", "EF Core")
Rel(userPreferences, dataAccess, "Reads/Writes display preferences", "EF Core")

' === Infrastructure → External relationships ===

Rel(claudeClient, claude, "Normalizes, classifies, optimizes", "HTTPS/JSON")
Rel(anthropicTestClient, claude, "One-token Messages ping for Test Connection", "HTTPS/JSON")
Rel(dataAccess, db, "Reads/Writes", "EF Core / Npgsql")

@enduml
